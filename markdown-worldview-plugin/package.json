{
  "name": "markdown-worldview",
  "version": "0.1.0-beta.1",
  "description": "A markdown-it plugin for rendering interactive worldview components with YAML syntax",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "markdown-it",
    "markdown",
    "plugin",
    "worldview",
    "wiki",
    "vitepress",
    "yaml",
    "components"
  ],
  "author": "NekoMake",
  "license": "MIT",
  "peerDependencies": {
    "markdown-it": "^14.0.0",
    "echarts": "^5.5.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0",
    "echarts": "^5.5.0",
    "jsdom": "^29.0.1",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.4.0",
    "typescript": "^5.7.2",
    "vis-timeline": "^7.7.3",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8",
    "vue": "^3.5.31"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NekoMake/markdown-worldview.git"
  },
  "bugs": {
    "url": "https://github.com/NekoMake/markdown-worldview/issues"
  },
  "homepage": "https://github.com/NekoMake/markdown-worldview#readme"
}
